# Copy this file to ".env" (same folder) and adjust as needed.
# The app reads config from environment variables / this file via
# app/core/settings.py - nothing else needs to change.

# --- Ollama / LLM config ---
# Must match wherever your Ollama instance is actually reachable.
# Examples:
#   Local install:     http://localhost:11434
#   Docker container:  http://ollama:11434   (if backend is also in Docker on the same network)
#   Remote machine/VM: http://<host-ip>:11434
OLLAMA_URL=http://localhost:11434

# Must be a model you have already pulled, e.g.: ollama pull llama3
OLLAMA_MODEL=llama3:latest

# Seconds to wait for Ollama to respond. Local inference (especially the
# first call after a model loads into memory) can take a while - raise this
# if you see "Ollama request timed out" in the logs.
OLLAMA_TIMEOUT=30

# --- App config (all optional, shown with defaults) ---
# APP_NAME=GuardFlow
# HOST=0.0.0.0
# PORT=8000
# DEBUG=False
# DATABASE_URL=sqlite:///./data/guardflow.db
# LOG_LEVEL=INFO
# ALLOWED_ORIGINS=["http://localhost:5173"]
